{
  "name": "ngx-datawindow",
  "version": "1.0.0",
  "description": "Angular DataWindow component inspired by PowerBuilder DataWindow — DataStore engine, virtual computed columns, column-level change tracking, offline persistence, and optimistic locking.",
  "scripts": {
    "build": "ng-packagr -p projects/ngx-datawindow/ng-package.json",
    "build:lib": "ng-packagr -p projects/ngx-datawindow/ng-package.json",
    "watch": "ng-packagr -p projects/ngx-datawindow/ng-package.json --watch",
    "start": "ng serve example --port 4200 --host localhost",
    "build:example": "ng build example",
    "test": "ng test"
  },
  "peerDependencies": {
    "@angular/cdk": ">=17.0.0",
    "@angular/common": ">=17.0.0",
    "@angular/core": ">=17.0.0",
    "@angular/material": ">=17.0.0",
    "@angular/forms": ">=17.0.0"
  },
  "dependencies": {
    "tslib": "^2.6.0",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular/animations": "^21.2.10",
    "@angular/build": "^21.2.8",
    "@angular/cdk": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/common": "^21.2.10",
    "@angular/compiler": "^21.2.10",
    "@angular/compiler-cli": "^21.2.10",
    "@angular/core": "^21.2.10",
    "@angular/forms": "^21.2.10",
    "@angular/material": "^21.2.8",
    "@angular/platform-browser": "^21.2.10",
    "@angular/platform-browser-dynamic": "^21.2.10",
    "@angular/router": "^21.2.10",
    "@types/jest": "^29.5.0",
    "fake-indexeddb": "^6.2.5",
    "jest": "29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "ng-packagr": "^21.2.3",
    "ts-jest": "29.2.0",
    "typescript": "~5.9.3"
  }
}
